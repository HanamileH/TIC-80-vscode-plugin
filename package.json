{
    "name": "tic80-cartridge-tool",
    "displayName": "TIC-80 Cartridge Tool",
    "description": "TIC-80 game development extension for VS Code",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "workspaceContains:tic80_project.json"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "tic80.helloWorld",
                "title": "TIC-80: Hello World"
            },
            {
                "command": "tic80.showDashboard",
                "title": "TIC-80: Show Dashboard"
            }
        ],
        "configuration": {
            "title": "TIC-80",
            "properties": {
                "tic80.author": {
                    "type": "string",
                    "default": "Unknown",
                    "description": "Default author name for new projects"
                },
                "tic80.defaultScriptLanguage": {
                    "type": "string",
                    "enum": ["lua", "javascript", "fennel", "wren", "squirrel"],
                    "default": "lua",
                    "description": "Default script language for new projects"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "^16.18.34",
        "typescript": "^5.2.2"
    }
}